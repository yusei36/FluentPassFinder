<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FluentPassFinder.Views"
        xmlns:models="clr-namespace:FluentPassFinder.ViewModels"
        xmlns:contracts="clr-namespace:FluentPassFinder.Contracts"
        xmlns:converters="clr-namespace:FluentPassFinder.Converters"
        xmlns:icons="clr-namespace:FluentPassFinder.Services.Actions"
        x:Class="FluentPassFinder.Views.SearchWindow"
        x:ClassModifier="internal"
        x:Name="WindowRoot"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:SearchWindow}"
        Title="{Binding ViewModel.ApplicationTitle, Mode=OneWay}"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        Width="500"
        MinHeight="40"
        Height="40"
        SizeToContent="Height"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
		FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        Background="Transparent">

    <Window.Resources>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
        <converters:StringEmptyConverter x:Key="StringEmptyConverter" />
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="Escape"       Command="{Binding HideSearchWindowCommand}" />
        <KeyBinding Gesture="Return"       Command="{Binding ViewModel.EnterActionCommand}" />
        <KeyBinding Gesture="Shift+Return" Command="{Binding ViewModel.ShiftEnterActionCommand}" />
        <KeyBinding Gesture="Ctrl+Return"  Command="{Binding ViewModel.ControlEnterActionCommand}" />
        <KeyBinding Gesture="Alt+Return"   Command="{Binding ViewModel.AltEnterActionCommand}" />
        <KeyBinding Gesture="Down"         Command="{Binding ViewModel.NavigateListDownCommand}" />
        <KeyBinding Gesture="Up"           Command="{Binding ViewModel.NavigateListUpCommand}" />
    </Window.KeyBindings>

    <Border CornerRadius="8"
            ClipToBounds="True"
            Background="{DynamicResource SystemAltHighColor}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" MaxHeight="500" />
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox"
                     Grid.Row="0"
                     Watermark="Search"
					 FontSize="16"
					 Classes.hideCaret="{Binding ViewModel.IsContextMenuOpen}"
                     IsReadOnly="{Binding ViewModel.IsContextMenuOpen}"
					 Text="{Binding ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Styles>
                    <Style Selector="TextBox.hideCaret">
                        <Setter Property="CaretBrush" Value="Transparent" />
                    </Style>
                </TextBox.Styles>
                <TextBox.InnerRightContent>
                    <StackPanel Orientation="Horizontal"
                                IsVisible="{Binding ViewModel.IsContextMenuOpen, Converter={StaticResource InvertBoolConverter}}">
                        <Button Command="{Binding ViewModel.ClearSearchCommand}"
                                Click="ClearSearchButton_Click"
                                IsVisible="{Binding ViewModel.SearchText, Converter={StaticResource StringEmptyConverter}, ConverterParameter=Invert}"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Clear">
                            <PathIcon Width="10"
                                      Height="10"
                                      Data="{x:Static icons:Icons.Close}" />
                        </Button>
                        <Button Command="{Binding ViewModel.ToggleSettingsCommand}"
                                IsVisible="{Binding ViewModel.SearchText, Converter={StaticResource StringEmptyConverter}}"
                                Width="28"
                                Height="28"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                VerticalAlignment="Center"
                                ToolTip.Tip="Settings">
                            <PathIcon Width="14"
                                      Height="14"
                                      Data="{x:Static icons:Icons.Settings}" />
                        </Button>
                        <PathIcon Width="16"
                                  Height="16"
                                  Margin="0 0 8 0"
                                  Data="{x:Static icons:Icons.Search}" />
                    </StackPanel>
                </TextBox.InnerRightContent>
                <TextBox.KeyBindings>
                    <KeyBinding Gesture="Down" Command="{Binding ViewModel.NavigateListDownCommand}" />
                    <KeyBinding Gesture="Up"   Command="{Binding ViewModel.NavigateListUpCommand}" />
                </TextBox.KeyBindings>
            </TextBox>

            <ContentControl Grid.Row="1"
                            Content="{Binding SettingsView}"
                            IsVisible="{Binding ViewModel.IsSettingsOpen}" />

            <Panel Grid.Row="1"
                   IsVisible="{Binding ViewModel.IsSettingsOpen, Converter={StaticResource InvertBoolConverter}}">

            <ListBox ItemsSource="{Binding ViewModel.Entries}"
                     SelectedItem="{Binding ViewModel.SelectedEntry}"
                     SelectionChanged="ListBox_SelectionChanged"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     IsVisible="{Binding ViewModel.IsContextMenuOpen, Converter={StaticResource InvertBoolConverter}}">
				<ListBox.Styles>
					<Style Selector="ListBoxItem">
						<Setter Property="Padding" Value="6 2 2 2" />
					</Style>
				</ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="models:EntryViewModel">
                        <Grid Margin="0,0"
                              Background="Transparent"
                              ToolTip.Tip="{Binding Title}"
                              PointerReleased="EntryGrid_PointerReleased">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Grid.RowSpan="2"
                                    Width="3"
                                    Height="16"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource SystemAccentColorLight2}"
                                    IsVisible="{Binding $parent[ListBoxItem].IsSelected}" />
                            <Image Grid.Column="1"
                                   Grid.Row="0"
                                   Grid.RowSpan="2"
                                   VerticalAlignment="Top"
                                   Margin="4 4 8 4"
                                   Width="16"
                                   Height="16"
                                   Source="{Binding Icon}" />
                            <TextBlock Grid.Column="2"
                                       Grid.Row="0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding Title}" />
                            <TextBlock Grid.Column="2"
                                       Grid.Row="1"
                                       FontSize="12"
                                       Text="{Binding UserName}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox ItemsSource="{Binding ViewModel.ContextActions}"
                     SelectedItem="{Binding ViewModel.SelectedContextAction}"
                     SelectionChanged="ListBox_SelectionChanged"
                     IsVisible="{Binding ViewModel.IsContextMenuOpen}">
				<ListBox.Styles>
					<Style Selector="ListBoxItem">
						<Setter Property="Padding" Value="4" />
					</Style>
				</ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="contracts:IAction">
                        <Grid Background="Transparent"
                              PointerReleased="ActionPanel_PointerReleased">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3" />
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0"
                                    Width="3"
                                    Height="16"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource SystemAccentColorLight2}"
                                    IsVisible="{Binding $parent[ListBoxItem].IsSelected}" />
                            <Grid Grid.Column="1"
                                  Width="26"
                                  Height="26"
                                  Margin="2,0">
                                <PathIcon Data="{Binding IconPath}"
                                          Width="16"
                                          Height="16"
                                          HorizontalAlignment="Left"
                                          VerticalAlignment="Center" />
                                <Border IsVisible="{Binding BadgePath, Converter={StaticResource StringEmptyConverter}, ConverterParameter=Invert}"
                                        Width="11"
                                        Height="11"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        CornerRadius="2">
                                    <PathIcon Data="{Binding BadgePath}"
                                              Width="9"
                                              Height="9" />
                                </Border>
                            </Grid>
                            <TextBlock Grid.Column="2"
                                       Margin="4,0"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{Binding DisplayName}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </Panel>
        </Grid>
    </Border>
</Window>
