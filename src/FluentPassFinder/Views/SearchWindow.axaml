<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FluentPassFinder.Views"
        xmlns:models="clr-namespace:FluentPassFinder.ViewModels"
        xmlns:contracts="clr-namespace:FluentPassFinder.Contracts"
        xmlns:converters="clr-namespace:FluentPassFinder.Converters"
        xmlns:icons="clr-namespace:FluentPassFinder.Services.Actions"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        x:Class="FluentPassFinder.Views.SearchWindow"
        x:ClassModifier="internal"
        x:DataType="local:SearchWindow"
        x:Name="WindowRoot"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance local:SearchWindow}"
        Title="{Binding ViewModel.ApplicationTitle, Mode=OneWay}"
        ShowInTaskbar="False"
        Topmost="True"
        CanResize="False"
        WindowStartupLocation="Manual"
        Width="450"
        MinHeight="40"
        SizeToContent="Height"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
		FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
        Background="Transparent">

    <Window.Resources>
        <converters:InvertBoolConverter x:Key="InvertBoolConverter" />
        <converters:StringEmptyConverter x:Key="StringEmptyConverter" />
        <ControlTheme TargetType="ListBoxItem" x:Key="{x:Type ListBoxItem}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="6 2 2 2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Panel>
                        <Border Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Margin="2">
                            <ContentPresenter Name="PART_ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <Rectangle Name="SelectionIndicator"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Width="3" Height="16"
                                   Margin="2 0 0 0"
                                   RadiusX="2" RadiusY="2"
                                   IsVisible="False"
                                   Fill="{DynamicResource AccentFillColorDefaultBrush}" />
                    </Panel>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:selected /template/ Border#Root">
                <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelected}" />
            </Style>
            <Style Selector="^:selected:pointerover /template/ Border#Root">
                <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundSelectedPointerOver}" />
            </Style>
            <Style Selector="^:pointerover:not(:selected) /template/ Border#Root">
                <Setter Property="Background" Value="{DynamicResource ListViewItemBackgroundPointerOver}" />
            </Style>
            <Style Selector="^:selected /template/ Rectangle#SelectionIndicator">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </ControlTheme>
    </Window.Resources>

    <Window.KeyBindings>
        <KeyBinding Gesture="Escape"       Command="{Binding ViewModel.NavigateBackCommand}" />
        <KeyBinding Gesture="Back"         Command="{Binding ViewModel.CloseContextMenuCommand}" />
        <KeyBinding Gesture="Left"         Command="{Binding ViewModel.CloseContextMenuCommand}" />
        <KeyBinding Gesture="Return"       Command="{Binding ViewModel.EnterActionCommand}" />
        <KeyBinding Gesture="Shift+Return" Command="{Binding ViewModel.ShiftEnterActionCommand}" />
        <KeyBinding Gesture="Ctrl+Return"  Command="{Binding ViewModel.ControlEnterActionCommand}" />
        <KeyBinding Gesture="Alt+Return"   Command="{Binding ViewModel.AltEnterActionCommand}" />
        <KeyBinding Gesture="Down"         Command="{Binding ViewModel.NavigateListDownCommand}" />
        <KeyBinding Gesture="Up"           Command="{Binding ViewModel.NavigateListUpCommand}" />
    </Window.KeyBindings>

    <Border CornerRadius="8"
            ClipToBounds="True"
            Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
        <Grid x:Name="MainGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Panel x:Name="HeaderPanel" Grid.Row="0">

                <!-- Normal search bar -->
                <TextBox x:Name="SearchBox"
                         IsVisible="{Binding ViewModel.IsSearchBarVisible}"
                         Watermark="Search"
                         FontSize="18"
                         Text="{Binding ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
					<TextBox.Resources>
						<ResourceDictionary>
							<!-- Dark-theme only, scoped to this search field: near-black rest/hover
							     surface that sinks to pure black on focus. Other TextBoxes keep the
							     default FluentAvalonia palette. -->
							<ResourceDictionary.ThemeDictionaries>
								<ResourceDictionary x:Key="Dark">
									<SolidColorBrush x:Key="TextControlBackground" Color="#0A0A0A" />
									<SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#0A0A0A" />
									<SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#000000" />
									<SolidColorBrush x:Key="TextControlBackgroundDisabled" Color="#000000" />
								</ResourceDictionary>
							</ResourceDictionary.ThemeDictionaries>
						</ResourceDictionary>
					</TextBox.Resources>
					<TextBox.Styles>
						<Style Selector="TextBox:focus-within /template/ Border#PART_BorderElement">
							<Setter Property="BorderBrush" Value="Transparent" />
						</Style>
					</TextBox.Styles>
					<TextBox.KeyBindings>
						<KeyBinding Gesture="Down" Command="{Binding ViewModel.NavigateListDownCommand}" />
						<KeyBinding Gesture="Up"   Command="{Binding ViewModel.NavigateListUpCommand}" />
					</TextBox.KeyBindings>
                    <TextBox.InnerRightContent>
						<!--Margin-Right: 3 is to align with the buttons in settings-->
                        <StackPanel Orientation="Horizontal" Margin="0 0 3 0">
							
                            <Button Command="{Binding ViewModel.ClearSearchCommand}"
                                    Click="ClearSearchButton_Click"
                                    IsVisible="{Binding ViewModel.SearchText, Converter={StaticResource StringEmptyConverter}, ConverterParameter=Invert}"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Clear">
                                <ui:FontIcon FontSize="14"
                                             FontFamily="{StaticResource SymbolFontFamily}"
                                             Glyph="{x:Static icons:Icons.Close}" />
                            </Button>
                            <Button Command="{Binding ViewModel.ToggleSettingsCommand}"
                                    IsVisible="{Binding ViewModel.SearchText, Converter={StaticResource StringEmptyConverter}}"
                                    Width="28"
                                    Height="28"
                                    Padding="0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Settings">
                                <ui:FontIcon FontSize="16"
                                             FontFamily="{StaticResource SymbolFontFamily}"
                                             Glyph="{x:Static icons:Icons.Settings}" />
                            </Button>
                        </StackPanel>
                    </TextBox.InnerRightContent>
                </TextBox>

                <!-- Context menu header: selected entry icon + title -->
                <Grid IsVisible="{Binding ViewModel.IsContextMenuOpen}"
                      ColumnDefinitions="Auto,*"
                      Margin="12 0">
                    <Image Grid.Column="0"
                           Source="{Binding ViewModel.SelectedEntry.Icon}"
                           Width="20"
                           Height="20"
                           Margin="0 0 8 0"
                           VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding ViewModel.SelectedEntry.Title}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <!-- Settings header: title + Save / Reset buttons -->
                <Grid IsVisible="{Binding ViewModel.IsSettingsOpen}"
                      ColumnDefinitions="*,Auto,Auto,Auto"
                      Margin="12 0 4 0">
                    <TextBlock Grid.Column="0"
                               Text="Settings"
                               FontSize="18"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Command="{Binding SettingsView.ViewModel.ResetToDefaultsCommand}"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Reset to defaults">
                        <ui:FontIcon FontSize="16"
                                     FontFamily="{StaticResource SymbolFontFamily}"
                                     Glyph="{x:Static icons:Icons.Reset}" />
                    </Button>
                    <Button Grid.Column="2"
                            Command="{Binding ViewModel.SaveSettingsAndCloseCommand}"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Save settings">
                        <ui:FontIcon FontSize="16"
                                     FontFamily="{StaticResource SymbolFontFamily}"
                                     Glyph="{x:Static icons:Icons.Save}" />
                    </Button>
                    <Button Grid.Column="3"
                            Command="{Binding ViewModel.NavigateBackCommand}"
                            Width="28"
                            Height="28"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="Discard and go back">
                        <ui:FontIcon FontSize="16"
                                     FontFamily="{StaticResource SymbolFontFamily}"
                                     Glyph="{x:Static icons:Icons.Close}" />
                    </Button>
                </Grid>

            </Panel>

            <ContentControl x:Name="SettingsContent"
                            Grid.Row="1"
                            Content="{Binding SettingsView}"
                            IsVisible="{Binding ViewModel.IsSettingsOpen}" />

            <Panel x:Name="ResultsPanel"
                   Grid.Row="1"
                   IsVisible="{Binding ViewModel.IsSettingsOpen, Converter={StaticResource InvertBoolConverter}}">

            <ListBox ItemsSource="{Binding ViewModel.Entries}"
                     SelectedItem="{Binding ViewModel.SelectedEntry}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     IsVisible="{Binding ViewModel.IsContextMenuOpen, Converter={StaticResource InvertBoolConverter}}"
                     Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:EntryViewModel">
                        <Grid Margin="0,0"
                              Background="Transparent"
                              ToolTip.Tip="{Binding Title}"
                              PointerReleased="EntryGrid_PointerReleased">
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Image Grid.Column="0"
                                   Grid.Row="0"
                                   Grid.RowSpan="2"
                                   VerticalAlignment="Top"
                                   Margin="4 4 8 4"
                                   Width="16"
                                   Height="16"
                                   Source="{Binding Icon}" />
                            <TextBlock Grid.Column="1"
                                       Grid.Row="0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding Title}" />
                            <TextBlock Grid.Column="1"
                                       Grid.Row="1"
                                       FontSize="12"
                                       Text="{Binding UserName}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <ListBox ItemsSource="{Binding ViewModel.ContextActions}"
                     SelectedItem="{Binding ViewModel.SelectedContextAction}"
                     IsVisible="{Binding ViewModel.IsContextMenuOpen}"
                     Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
				<ListBox.Styles>
					<Style Selector="ListBoxItem">
						<Setter Property="Padding" Value="4" />
					</Style>
				</ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="contracts:IAction">
                        <Grid Background="Transparent"
                              PointerReleased="ActionPanel_PointerReleased">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="26" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0"
                                  Width="26"
                                  Height="26"
                                  Margin="2,0">
                                <ui:FontIcon Glyph="{Binding IconGlyph}"
                                             FontFamily="{StaticResource SymbolFontFamily}"
                                             FontSize="18"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center" />
                                <Border IsVisible="{Binding BadgeGlyph, Converter={StaticResource StringEmptyConverter}, ConverterParameter=Invert}"
                                        Width="11"
                                        Height="11"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        CornerRadius="2">
                                    <ui:FontIcon Glyph="{Binding BadgeGlyph}"
                                                 FontFamily="{StaticResource SymbolFontFamily}"
                                                 FontSize="10" />
                                </Border>
                            </Grid>
                            <TextBlock Grid.Column="1"
                                       Margin="4,0"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Text="{Binding DisplayName}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            </Panel>
        </Grid>
    </Border>
</Window>
