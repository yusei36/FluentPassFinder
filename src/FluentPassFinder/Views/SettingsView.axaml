<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:FluentPassFinder.Views"
             xmlns:models="clr-namespace:FluentPassFinder.ViewModels"
             xmlns:converters="clr-namespace:FluentPassFinder.Converters"
             xmlns:icons="clr-namespace:FluentPassFinder.Services.Actions"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="FluentPassFinder.Views.SettingsView"
             x:ClassModifier="internal"
             x:DataType="local:SettingsView"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance local:SettingsView}">

    <UserControl.Resources>
        <converters:WindowAnchorConverter x:Key="WindowAnchorConverter" />
    </UserControl.Resources>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12 8 12 12" Spacing="4">

            <!-- Appearance -->
            <TextBlock Text="Appearance"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Margin="0 4 0 2" />

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Theme" VerticalAlignment="Center" FontSize="13" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static models:SettingsViewModel.AvailableThemes}"
                          SelectedItem="{Binding ViewModel.Theme}"
                          HorizontalAlignment="Stretch"
                          FontSize="13" />
            </Grid>

            <Separator Margin="0 6" />

            <!-- Key Bindings -->
            <TextBlock Text="Key Bindings"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Margin="0 0 0 2" />

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Hotkey (current screen)" VerticalAlignment="Center" FontSize="13" />
                <TextBox Grid.Column="1"
                         Text="{Binding ViewModel.GlobalHotkeyCurrentScreen}"
                         FontSize="13" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Hotkey (primary screen)" VerticalAlignment="Center" FontSize="13" />
                <TextBox Grid.Column="1"
                         Text="{Binding ViewModel.GlobalHotkeyPrimaryScreen}"
                         FontSize="13" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Enter" VerticalAlignment="Center" FontSize="13" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static models:SettingsViewModel.AvailableActions}"
                          SelectedItem="{Binding ViewModel.MainAction}"
                          HorizontalAlignment="Stretch"
                          FontSize="12" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Shift+Enter" VerticalAlignment="Center" FontSize="13" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static models:SettingsViewModel.AvailableActions}"
                          SelectedItem="{Binding ViewModel.ShiftAction}"
                          HorizontalAlignment="Stretch"
                          FontSize="12" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Ctrl+Enter" VerticalAlignment="Center" FontSize="13" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static models:SettingsViewModel.AvailableActions}"
                          SelectedItem="{Binding ViewModel.ControlAction}"
                          HorizontalAlignment="Stretch"
                          FontSize="12" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Alt+Enter" VerticalAlignment="Center" FontSize="13" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static models:SettingsViewModel.AvailableActions}"
                          SelectedItem="{Binding ViewModel.AltAction}"
                          HorizontalAlignment="Stretch"
                          FontSize="12" />
            </Grid>

            <Separator Margin="0 6" />

            <!-- Window Behavior -->
            <TextBlock Text="Window Behavior"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Margin="0 0 0 2" />

            <CheckBox IsChecked="{Binding ViewModel.EscAlwaysClosesWindow}"
                      Content="Esc closes window instead of navigating back"
                      FontSize="13"
                      Margin="0 2" />

            <CheckBox IsChecked="{Binding ViewModel.PreserveLastSearch}"
                      Content="Preserve last search when reopening"
                      FontSize="13"
                      Margin="0 2" />

            <Grid ColumnDefinitions="*,*" Margin="0 2"
                  IsEnabled="{Binding ViewModel.PreserveLastSearch}">
                <TextBlock Grid.Column="0" Text="Clear after (seconds)" VerticalAlignment="Center" FontSize="13" />
                <NumericUpDown Grid.Column="1"
                               Value="{Binding ViewModel.PreserveLastSearchTimeoutSeconds}"
                               Minimum="5"
                               Maximum="300"
                               Increment="5"
                               FontSize="13" />
            </Grid>

            <Separator Margin="0 6" />

            <!-- Window Layout -->
            <TextBlock Text="Window Layout"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Margin="0 0 0 2" />

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Window anchor" VerticalAlignment="Center" FontSize="13" />
                <ComboBox Grid.Column="1"
                          ItemsSource="{x:Static models:SettingsViewModel.AvailableWindowAnchors}"
                          SelectedItem="{Binding ViewModel.WindowAnchor}"
                          HorizontalAlignment="Stretch"
                          FontSize="13">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource WindowAnchorConverter}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Window width" VerticalAlignment="Center" FontSize="13" />
                <NumericUpDown Grid.Column="1"
                               Value="{Binding ViewModel.WindowWidth}"
                               Minimum="200"
                               Maximum="4000"
                               Increment="10"
                               FontSize="13" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2"
                  ToolTip.Tip="Maximum height of the results area (excludes the 40 px search bar)">
                <TextBlock Grid.Column="0" Text="Window height" VerticalAlignment="Center" FontSize="13" />
                <NumericUpDown Grid.Column="1"
                               Value="{Binding ViewModel.WindowHeight}"
                               Minimum="50"
                               Maximum="4000"
                               Increment="10"
                               FontSize="13" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Window offset X" VerticalAlignment="Center" FontSize="13" />
                <NumericUpDown Grid.Column="1"
                               Value="{Binding ViewModel.WindowOffsetX}"
                               Minimum="-4000"
                               Maximum="4000"
                               Increment="10"
                               FontSize="13" />
            </Grid>

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="Window offset Y" VerticalAlignment="Center" FontSize="13" />
                <NumericUpDown Grid.Column="1"
                               Value="{Binding ViewModel.WindowOffsetY}"
                               Minimum="-4000"
                               Maximum="4000"
                               Increment="10"
                               FontSize="13" />
            </Grid>

            <Separator Margin="0 6" />

            <!-- Search Behavior -->
            <TextBlock Text="Search Behavior"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Margin="0 0 0 2" />
			<CheckBox IsChecked="{Binding ViewModel.ExcludeExpiredEntries}"        Content="Exclude expired entries"       FontSize="13" />
			<CheckBox IsChecked="{Binding ViewModel.ExcludeGroupsBySearchSetting}" Content="Respect group search setting"  FontSize="13" />
			<CheckBox IsChecked="{Binding ViewModel.ResolveFieldReferences}"       Content="Resolve field references"      FontSize="13" />

            <CheckBox IsChecked="{Binding ViewModel.ShowActionsForCustomFields}"
                      Content="Show actions for custom fields"
                      FontSize="13"
                      Margin="0 2" />

            <Separator Margin="0 6" />

            <!-- Search Fields -->
            <TextBlock Text="Search Fields"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Margin="0 0 0 2" />

            <CheckBox IsChecked="{Binding ViewModel.IncludeTitleField}"     Content="Title"                    FontSize="13" />
            <CheckBox IsChecked="{Binding ViewModel.IncludeUserNameField}"  Content="Username"                 FontSize="13" />
            <CheckBox IsChecked="{Binding ViewModel.IncludePasswordField}"  Content="Password"                 FontSize="13" />
            <CheckBox IsChecked="{Binding ViewModel.IncludeUrlField}"       Content="URL"                      FontSize="13" />
            <CheckBox IsChecked="{Binding ViewModel.IncludeNotesField}"     Content="Notes"                    FontSize="13" />
            <CheckBox IsChecked="{Binding ViewModel.IncludeTags}"           Content="Tags"                     FontSize="13" />
            <CheckBox IsChecked="{Binding ViewModel.IncludeCustomFields}"   Content="Custom fields"            FontSize="13" />
            <CheckBox IsChecked="{Binding ViewModel.IncludeProtectedCustomFields}" Content="Protected custom fields" FontSize="13" />

            <Separator Margin="0 6" />

            <!-- TOTP -->
            <TextBlock Text="TOTP"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Opacity="0.6"
                       Margin="0 0 0 2" />

            <Grid ColumnDefinitions="*,*" Margin="0 2">
                <TextBlock Grid.Column="0" Text="TOTP placeholder" VerticalAlignment="Center" FontSize="13" />
                <TextBox Grid.Column="1"
                         Text="{Binding ViewModel.TotpPlaceholder}"
                         FontSize="13" />
            </Grid>

            <Separator Margin="0 6" />

            <!-- Advanced -->
            <Expander HorizontalAlignment="Stretch"
                      Margin="0 2">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ui:FontIcon FontSize="16" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Options}" VerticalAlignment="Center" />
                        <TextBlock Text="Advanced" VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="4">

                    <!-- Hide Actions For Fields -->
                    <TextBlock Text="Hide Actions For Fields"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Opacity="0.6"
                               Margin="0 0 0 2" />

                    <StackPanel Margin="0 2" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <TextBox Grid.Column="0"
                                     Height="32"
                                     Text="{Binding ViewModel.NewExcludeField}"
                                     Watermark="Field name"
                                     VerticalContentAlignment="Center"
                                     FontSize="13">
                                <TextBox.KeyBindings>
                                    <KeyBinding Gesture="Return" Command="{Binding ViewModel.AddExcludeFieldCommand}" />
                                </TextBox.KeyBindings>
                            </TextBox>
                            <Button Grid.Column="1"
                                    Command="{Binding ViewModel.AddExcludeFieldCommand}"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    ToolTip.Tip="Add field">
                                <ui:FontIcon FontSize="16" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Add}" />
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ViewModel.ExcludeFields}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10 0 4 0"
                                            Height="32">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis" />
                                            <Button Grid.Column="1"
                                                    Command="{Binding $parent[ItemsControl].((local:SettingsView)DataContext).ViewModel.RemoveExcludeFieldCommand}"
                                                    CommandParameter="{Binding}"
                                                    Width="24"
                                                    Height="24"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    ToolTip.Tip="Remove">
                                                <ui:FontIcon FontSize="14" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Close}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Separator Margin="0 6" />

                    <!-- Action Order -->
                    <TextBlock Text="Action Order"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Opacity="0.6"
                               Margin="0 0 0 2" />

                    <TextBlock FontSize="12"
                               Opacity="0.6"
                               TextWrapping="Wrap"
                               Margin="0 0 0 4">
                        <Run Text="Sort index per action; lower sorts first, a negative index hides it. Add an action by its raw name; anything not listed uses its built-in index." />
                        <LineBreak />
                        <Run Text="Reference:" />
                        <LineBreak />
                        <Run Text="AutoType 0, Copy_Totp 100, AutoType_Totp 150, OpenUrl 200, SelectEntry 300, Copy_&lt;field&gt; 1000, AutoType_&lt;field&gt; 2000" />
                    </TextBlock>

                    <StackPanel Margin="0 2" Spacing="6">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                            <AutoCompleteBox Grid.Column="0"
                                             Height="32"
                                             Text="{Binding ViewModel.NewSortingAction}"
                                             ItemsSource="{x:Static models:SettingsViewModel.AvailableActions}"
                                             FilterMode="Contains"
                                             Watermark="Action name"
                                             FontSize="13">
                                <AutoCompleteBox.KeyBindings>
                                    <KeyBinding Gesture="Return" Command="{Binding ViewModel.AddSortingActionCommand}" />
                                </AutoCompleteBox.KeyBindings>
                            </AutoCompleteBox>
                            <Button Grid.Column="1"
                                    Command="{Binding ViewModel.AddSortingActionCommand}"
                                    Width="32"
                                    Height="32"
                                    Padding="0"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    ToolTip.Tip="Add action">
                                <ui:FontIcon FontSize="16" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Add}" />
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ViewModel.SortingActions}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="3" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:SortingActionItem">
                                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10 0 4 0"
                                            Height="32">
                                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding ActionType}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis" />
                                            <NumericUpDown Grid.Column="1"
                                                           Value="{Binding Index}"
                                                           Minimum="-1"
                                                           Maximum="100000"
                                                           Increment="1"
                                                           FormatString="0"
                                                           Width="110"
                                                           Height="26"
                                                           VerticalAlignment="Center"
                                                           FontSize="12" />
                                            <Button Grid.Column="2"
                                                    Command="{Binding $parent[ItemsControl].((local:SettingsView)DataContext).ViewModel.RemoveSortingActionCommand}"
                                                    CommandParameter="{Binding}"
                                                    Width="24"
                                                    Height="24"
                                                    Padding="0"
                                                    VerticalAlignment="Center"
                                                    HorizontalContentAlignment="Center"
                                                    VerticalContentAlignment="Center"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    ToolTip.Tip="Remove">
                                                <ui:FontIcon FontSize="14" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Close}" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- About -->
            <Expander HorizontalAlignment="Stretch"
                      Margin="0 2">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ui:FontIcon FontSize="16" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Info}" VerticalAlignment="Center" />
                        <TextBlock Text="About" VerticalAlignment="Center" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="4">

                    <TextBlock VerticalAlignment="Center" FontSize="13" Margin="0 2">
                        <Run Text="FluentPassFinder" />
                        <Run Text="{x:Static models:SettingsViewModel.Copyright}" />
                    </TextBlock>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Margin="0 2">
                        <TextBlock Grid.Column="0" Text="Version" VerticalAlignment="Center" FontSize="13" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Static models:SettingsViewModel.AppVersion}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="2"
                                Command="{Binding ViewModel.CopyToClipboardCommand}"
                                CommandParameter="{x:Static models:SettingsViewModel.AppVersionFull}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                ToolTip.Tip="Copy version">
                            <ui:FontIcon FontSize="14" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Copy}" />
                        </Button>
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6" Margin="0 2">
                        <TextBlock Grid.Column="0" Text="License" VerticalAlignment="Center" FontSize="13" />
                        <TextBlock Grid.Column="1"
                                   Text="GNU GPL v3.0 or later"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Opacity="0.7"
                                   FontSize="13" />
                        <Button Grid.Column="2"
                                Command="{Binding ViewModel.OpenUrlCommand}"
                                CommandParameter="{x:Static models:SettingsViewModel.LicenseUrl}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                ToolTip.Tip="Open license text">
                            <ui:FontIcon FontSize="14" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Document}" />
                        </Button>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0 2">
                        <TextBlock Grid.Column="0" Text="Source code" VerticalAlignment="Center" FontSize="13" />
                        <Button Grid.Column="1"
                                Command="{Binding ViewModel.OpenUrlCommand}"
                                CommandParameter="{x:Static models:SettingsViewModel.ProjectUrl}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                ToolTip.Tip="Open source code on GitHub">
                            <ui:FontIcon FontSize="14" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Globe}" />
                        </Button>
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto" Margin="0 2">
                        <TextBlock Grid.Column="0" Text="Report a bug" VerticalAlignment="Center" FontSize="13" />
                        <Button Grid.Column="1"
                                Command="{Binding ViewModel.OpenUrlCommand}"
                                CommandParameter="{x:Static models:SettingsViewModel.IssuesUrl}"
                                Width="32"
                                Height="32"
                                Padding="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                ToolTip.Tip="Open issue tracker on GitHub">
                            <ui:FontIcon FontSize="14" FontFamily="{StaticResource SymbolFontFamily}" Glyph="{x:Static icons:Icons.Globe}" />
                        </Button>
                    </Grid>

                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
